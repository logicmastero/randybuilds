# ── AI ─────────────────────────────────────────────────────────────────────
# Required for Claude-powered copy generation (headline, subhead, CTAs)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Database / Auth ─────────────────────────────────────────────────────────
# Required for lead storage, user auth, and file uploads
# Create a free project at: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Payments ────────────────────────────────────────────────────────────────
# Required to accept payments for delivered sites
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Queue / Workers ─────────────────────────────────────────────────────────
# Only needed if running Puppeteer workers on Railway
# Leave blank for Vercel-only deploys (Cheerio scraper handles 95% of sites)
REDIS_URL=redis://default:password@your-redis.railway.internal:6379

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
